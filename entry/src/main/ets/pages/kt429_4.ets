@Entry
@Component
struct Kt429_4 {
  @State message: string = 'Hello World';

  controller:TabsController = new TabsController()

  build() {
    Column(){
      Tabs({barPosition:BarPosition.End,controller:this.controller}){
        TabContent(){
          Text('йҰ–йЎө').width('100%').height('100%').backgroundColor(Color.Pink)
        }.tabBar('йҰ–йЎө')
        TabContent(){
          Text('жҺўзҙў').width('100%').height('100%').backgroundColor(Color.Gray)
        }.tabBar('жҺўзҙў')
      }.vertical(false)
        .barMode(BarMode.Scrollable)
      .scrollable(true)
    }
    .height('100%')
    .width('100%')
  }
}